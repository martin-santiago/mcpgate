{
  "name": "mcp-gate",
  "version": "0.1.0",
  "description": "Lightweight MCP gateway — aggregate, filter, and observe your MCP tools",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "gateway",
    "proxy",
    "ai",
    "llm",
    "tools"
  ],
  "author": "Martin Santiago",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/mprezz/mcpgate"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-gate": "dist/index.js",
    "mcpgate": "dist/index.js"
  },
  "files": [
    "dist/",
    "mcpgate.example.yaml",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts -- start",
    "build": "tsc",
    "start": "node dist/index.js start",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^13.1.0",
    "hono": "^4.7.10",
    "pg": "^8.16.0",
    "pino": "^9.6.0",
    "yaml": "^2.7.1",
    "zod": "^3.25.32"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.15.2",
    "eslint": "^9.27.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vitest": "^3.1.4"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
