# MCPGate Environment Variables
# Copy this file to .env and fill in your values

# --- Gateway ---
# PORT=3000                          # HTTP port (Railway sets this automatically)
# LOG_LEVEL=info                     # debug | info | warn | error

# --- Config (for Railway/Docker — base64 encoded YAML) ---
# MCPGATE_CONFIG=                    # cat mcpgate.yaml | base64 -w 0

# --- Database (optional — enables persistent audit trail) ---
# DATABASE_URL=                      # PostgreSQL connection string

# --- Upstream Server Secrets (referenced in mcpgate.yaml via ${VAR}) ---
# GITHUB_TOKEN=
# ANTHROPIC_API_KEY=
